{
  "name": "id-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "oxfmt . && oxfmt --config .oxfmtrc-css.json src/**/*.css",
